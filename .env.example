# Dear Pet Box — 환경변수 예시 (.env.local 로 복사 후 실제 값 입력)

# Supabase (인증 + DB)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PortOne v2 (결제)
NEXT_PUBLIC_PORTONE_STORE_ID=
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=

# GA4 (분석) — 설정 시에만 로드됨
NEXT_PUBLIC_GA_ID=

# 카카오 (소셜 로그인 / 알림톡)
NEXT_PUBLIC_KAKAO_JS_KEY=
